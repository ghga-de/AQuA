{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/GHGA/qc/master/assets/schema_input.json",
    "title": "ghga_de qcmetrics pipeline params input schema",
    "description": "Schema for the file provided with params input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample ID must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "individual_id": {
                "type": "string",
                "errorMessage": "Individual ID cannot contain spaces",
                "meta": ["individual_id"]
            },
            "sex": {
                "errorMessage": "Sex cannot contain spaces",
                "meta": ["sex"],
                "default": "NA",
                "type": "string",
                "pattern": "^\\S+$"
            },
            "phenotype": {
                "type": "string",
                "meta": ["phenotype"]
            },
            "sample_type": {
                "type": "string",
                "meta": ["sample_type"]
            },
            "disease_status": {
                "type": "string",
                "meta": ["disease_status"]
            },
            "case_control_status": {
                "type": "string",
                "meta": ["case_control_status"]
            },
            "tissue": {
                "type": "string",
                "meta": ["tissue"]
            },
            "experiment_method": {
                "type": "string",
                "meta": ["experiment_method"]
            },
            "analysis_method": {
                "type": "string",
                "meta": ["analysis_method"]
            },
            "data_files": {
                "type": "string",
                "errorMessage": "Data files must be provided",
                "meta": ["data_files"]
            },
            "fastq_1": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.f(ast)?q\\.gz$",
                "errorMessage": "FastQ file for reads 1 must be provided, cannot contain spaces and must have extension '.fq.gz' or '.fastq.gz'"
            },
            "fastq_2": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.f(ast)?q\\.gz$",
                "errorMessage": "FastQ file for reads 2 cannot contain spaces and must have extension '.fq.gz' or '.fastq.gz'"
            },
            "status": {
                "type": "integer",
                "errorMessage": "Status can only be 0 (normal) or 1 (tumor). Defaults to 0, if none is supplied.",
                "meta": ["status"],
                "default": 0,
                "minimum": 0,
                "maximum": 1
            },
            "lane": {
                "type": "string",
                "pattern": "^\\S+$",
                "meta": ["lane"]
            },
            "single_end": {
                "type": "boolean",
                "meta": ["single_end"]
            },
            "cram": {
                "errorMessage": "CRAM file cannot contain spaces and must have extension '.cram'",
                "type": "string",
                "pattern": "^\\S+\\.cram$",
                "format": "file-path",
                "exists": true
            },
            "crai": {
                "errorMessage": "CRAM index file cannot contain spaces and must have extension '.crai'",
                "type": "string",
                "pattern": "^\\S+\\.crai$",
                "format": "file-path",
                "exists": true
            },
            "bam": {
                "errorMessage": "BAM file cannot contain spaces and must have extension '.bam'",
                "type": "string",
                "pattern": "^\\S+\\.bam$",
                "format": "file-path",
                "exists": true
            },
            "bai": {
                "errorMessage": "BAM index file cannot contain spaces and must have extension '.bai'",
                "type": "string",
                "pattern": "^\\S+\\.bai$",
                "format": "file-path",
                "exists": true
            },
            "vcf": {
                "errorMessage": "VCF file for reads 1 cannot contain spaces and must have extension '.vcf' or '.vcf.gz'",
                "type": "string",
                "pattern": "^\\S+\\.vcf(\\.gz)?$",
                "format": "file-path",
                "exists": true
            }
        },
        "oneOf": [
            { "required": ["fastq_1"], "not": { "required": ["bam", "cram", "vcf", "data_files"] } },
            { "required": ["bam"], "not": { "required": ["fastq_1", "cram", "vcf", "data_files"] } },
            { "required": ["cram"], "not": { "required": ["fastq_1", "vcf", "bam", "data_files"] } },
            { "required": ["vcf"], "not": { "required": ["fastq_1", "cram", "bam", "data_files"] } },
            { "required": ["data_files"], "not": { "required": ["fastq_1", "cram", "bam", "vcf"] } }
        ],
        "required": ["sample"]
    }
}